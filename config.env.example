# ================================================================================
#   ANSI PROJECT — CONFIGURAÇÕES DE AMBIENTE
#   Copie este arquivo para config.env e preencha os valores.
#   NUNCA commite o config.env — ele está no .gitignore.
# ================================================================================

# OBRIGATÓRIO em produção. Se vazio, o código cai num fallback hardcoded
# inseguro (tokens forjáveis). Gere um valor forte e único por ambiente.
JWT_SECRET_KEY=
# Tempo de sessão (ociosidade máx., em minutos). A sliding session renova a
# cada request. Se vazio, default = 5 (curto demais — sessão estoura no meio
# de um formulário). Sugestão produção: 60.
JWT_EXPIRE_MINUTES=
JWT_ALGORITHM=HS256

# OBRIGATÓRIOS para envio de e-mail (senha do bootstrap, reset de senha).
# Se vazios, os e-mails falham silenciosamente. EMAIL_SENHA_APP é a senha de
# app do Gmail (não a senha da conta).
EMAIL_REMETENTE=
EMAIL_SENHA_APP=     # senha de app do Gmail (não a senha da conta); gerar em myaccount.google.com

DB_HOST=localhost
DB_PORT=5432
DB_NAME=AMSI_Project
DB_USER=
DB_PASSWORD=

NGROK_TOKEN=
NGROK_DOMAIN=

TELEGRAM_BOT_TOKEN=
TELEGRAM_GROUP_ID=

APP_ENV=development
APP_HOST=localhost
APP_PORT=8000

# URL pública do frontend (usada em links de e-mail e CORS). Em produção,
# aponta para o deploy do Vercel. Ex.: https://amsi-frontend.vercel.app
FRONTEND_URL=

# ================================================================================
#   USUÁRIOS DE TESTE (pytest) — só afetam os testes automatizados, não o app.
#   Já têm default hardcoded em backend/utils/config.py; não é preciso preencher
#   nada aqui a menos que queira customizar email/senha usados pelo bootstrap
#   e pelas fixtures do pytest.
# --------------------------------------------------------------------------------
CONSULTA_TESTE_EMAIL=     # default: pytest_consulta@amsi.com
CONSULTA_TESTE_SENHA=     # default: consultaTeste123

OPERADOR_TESTE_EMAIL=     # default: pytest_operador@amsi.com
OPERADOR_TESTE_SENHA=     # default: operadorTeste123

ADMIN_TESTE_EMAIL=        # default: pytest_admin@amsi.com
ADMIN_TESTE_SENHA=        # default: adminTeste123

# ================================================================================
#   FRONTEND (AMSI_Frontend) — variáveis do Vite
#   Não vão neste arquivo; ficam no .env do frontend e no painel do Vercel.
#   ATENÇÃO: o Vite INLINA as VITE_* em build time — alterar uma VITE_ no Vercel
#   só tem efeito após um novo `vercel --prod` (rebuild).
# --------------------------------------------------------------------------------
#   VITE_API_URL      → URL do backend (ex.: https://amsiproject-production.up.railway.app)
#   VITE_DB_SLEEP_MS  → opcional; default 120000 (retry quando o banco "acorda")
# ================================================================================